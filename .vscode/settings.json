{
  // ===== Prettier (only for frontend files) =====
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,

  // Global indentation (frontend)
  "editor.tabSize": 2,
  "editor.insertSpaces": true,

  // ===== C# backend formatting =====
  "[csharp]": {
    "editor.defaultFormatter": "ms-dotnettools.csharp",
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.formatOnSave": true
  },

  // ===== JSONC (settings.json itself) =====
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  }
}