{
  "manifest_version": 3,
  "name": "ChatGPT Conversation Navigator",
  "version": "0.1.0",
  "description": "Add a clickable navigation sidebar for ChatGPT conversations.",
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["pageHook.js"],
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"]
    }
  ]
}
